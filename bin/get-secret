#!/usr/bin/env bash
set -euo pipefail

# Description: Get a secret from macOS Keychain

usage() {
  cat <<'EOF'
get-secret — retrieve a secret from macOS Keychain

Usage:
  get-secret SECRET_NAME
  get-secret --help

Arguments:
  SECRET_NAME   The service name of the secret to retrieve

Example:
  get-secret GITHUB_TOKEN
EOF
}

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  usage
  exit 0
fi

if [[ -z "${1:-}" ]]; then
  echo "Error: No secret name provided" >&2
  usage >&2
  exit 1
fi

if ! result=$(security find-generic-password -a "$USER" -s "$1" -w 2>/dev/null); then
  echo "Error: Could not find secret '$1' for account '$USER'" >&2
  exit 1
fi

printf '%s\n' "$result"

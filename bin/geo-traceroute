#!/usr/bin/env bash
set -euo pipefail

# Usage:
#   geo-traceroute api.anthropic.com
#   traceroute api.anthropic.com | geo-traceroute -

if [[ "${1:-}" == "" ]]; then
  echo "usage: geo-traceroute <host>|-"
  exit 1
fi

input="$1"

if [[ "$input" == "-" ]]; then
  trace_output="$(cat)"
else
  trace_output="$(traceroute -n "$input")"
fi

# Extract IPv4s, preserve order, remove duplicates
ips=$(echo "$trace_output" \
  | grep -Eo '([0-9]{1,3}\.){3}[0-9]{1,3}' \
  | awk '!seen[$0]++')

for ip in $ips; do
  # Skip RFC1918
  if [[ "$ip" =~ ^10\. || "$ip" =~ ^192\.168\. || "$ip" =~ ^172\.(1[6-9]|2[0-9]|3[0-1])\. ]]; then
    printf "%-15s  private\n" "$ip"
    continue
  fi

  # Query ipinfo (JSON)
  json=$(curl -s "https://ipinfo.io/$ip")

  city=$(echo "$json" | jq -r '.city // "-"')
  region=$(echo "$json" | jq -r '.region // "-"')
  country=$(echo "$json" | jq -r '.country // "-"')
  org=$(echo "$json" | jq -r '.org // "-"')

  printf "%-15s  %-20s %-3s  %s\n" "$ip" "$city, $region" "$country" "$org"
done

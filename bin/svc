#!/bin/sh
set -u

prog=${0##*/}
config_dir=${SVC_CONFIG_DIR:-"$HOME/.config/svc"}
registry=${SVC_REGISTRY:-"$config_dir/services"}
launchagents_dir=${SVC_LAUNCHAGENTS_DIR:-"$HOME/Library/LaunchAgents"}

usage() {
	cat <<USAGE
Usage:
  $prog list
  $prog status <name>
  $prog start <name>
  $prog stop <name>
  $prog restart <name>
  $prog logs [-f] [-n lines] <name>
  $prog enable <name>
  $prog disable <name>
  $prog alias [short-name target]
  $prog unalias <short-name>

Names:
  macOS: a LaunchAgent label, plist basename, plist path, or alias.
  Linux: a systemd --user unit name, with or without .service, or alias.

Aliases live in:
  $registry

Examples:
  $prog list
  $prog status notes-sync
  $prog logs -f notes-sync
  $prog alias notes-sync com.jan.notes-sync
USAGE
}

die() {
	printf '%s: %s\n' "$prog" "$*" >&2
	exit 1
}

need() {
	command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"
}

expand_path() {
	case ${1:-} in
		"~")
			printf '%s\n' "$HOME"
			;;
		"~/"*)
			printf '%s/%s\n' "$HOME" "${1#~/}"
			;;
		*)
			printf '%s\n' "$1"
			;;
	esac
}

registry_lookup() {
	key=$1
	[ -f "$registry" ] || return 1

	value=$(
		awk -F= -v key="$key" '
			function trim(s) {
				sub(/^[[:space:]]+/, "", s)
				sub(/[[:space:]]+$/, "", s)
				return s
			}
			/^[[:space:]]*(#|$)/ { next }
			index($0, "=") == 0 { next }
			{
				k = trim($1)
				v = $0
				sub(/^[^=]*=/, "", v)
				v = trim(v)
				if (k == key) {
					print v
					exit
				}
			}
		' "$registry"
	)

	[ -n "$value" ] || return 1
	printf '%s\n' "$value"
}

registry_target() {
	if value=$(registry_lookup "$1"); then
		printf '%s\n' "$value"
	else
		printf '%s\n' "$1"
	fi
}

registry_alias_for() {
	label=$1
	path=$2
	tilde_path=$path
	case "$path" in
		"$HOME"/*)
			tilde_path="~/${path#$HOME/}"
			;;
	esac

	[ -f "$registry" ] || return 1
	alias_name=$(
		awk -F= -v label="$label" -v path="$path" -v tilde_path="$tilde_path" '
			function trim(s) {
				sub(/^[[:space:]]+/, "", s)
				sub(/[[:space:]]+$/, "", s)
				return s
			}
			/^[[:space:]]*(#|$)/ { next }
			index($0, "=") == 0 { next }
			{
				k = trim($1)
				v = $0
				sub(/^[^=]*=/, "", v)
				v = trim(v)
				if (v == label || v == path || v == tilde_path) {
					print k
					exit
				}
			}
		' "$registry"
	)

	[ -n "$alias_name" ] || return 1
	printf '%s\n' "$alias_name"
}

registry_set() {
	key=$1
	value=$2

	case "$key" in
		""|*"="*|*"#"*|*[[:space:]]*)
			die "alias names cannot be empty or contain whitespace, #, or ="
			;;
	esac
	[ -n "$value" ] || die "alias target cannot be empty"

	mkdir -p "$config_dir" || die "could not create $config_dir"
	tmp="$registry.$$"

	if [ -f "$registry" ]; then
		awk -F= -v key="$key" '
			function trim(s) {
				sub(/^[[:space:]]+/, "", s)
				sub(/[[:space:]]+$/, "", s)
				return s
			}
			index($0, "=") == 0 { print; next }
			trim($1) != key { print }
		' "$registry" >"$tmp" || {
			rm -f "$tmp"
			die "could not update $registry"
		}
	else
		: >"$tmp" || die "could not create $registry"
	fi

	printf '%s=%s\n' "$key" "$value" >>"$tmp" || {
		rm -f "$tmp"
		die "could not write $registry"
	}
	mv "$tmp" "$registry" || die "could not replace $registry"
	printf 'alias %s -> %s\n' "$key" "$value"
}

registry_unset() {
	key=$1
	[ -f "$registry" ] || die "no aliases configured at $registry"

	tmp="$registry.$$"
	awk -F= -v key="$key" '
		function trim(s) {
			sub(/^[[:space:]]+/, "", s)
			sub(/[[:space:]]+$/, "", s)
			return s
		}
		index($0, "=") == 0 { print; next }
		trim($1) != key { print }
	' "$registry" >"$tmp" || {
		rm -f "$tmp"
		die "could not update $registry"
	}
	mv "$tmp" "$registry" || die "could not replace $registry"
	printf 'removed alias %s\n' "$key"
}

registry_print() {
	if [ -f "$registry" ]; then
		awk '
			/^[[:space:]]*(#|$)/ { next }
			{ print }
		' "$registry"
	else
		printf 'no aliases configured at %s\n' "$registry"
	fi
}

plist_value() {
	plist=$1
	key=$2
	/usr/libexec/PlistBuddy -c "Print :$key" "$plist" 2>/dev/null
}

macos_domain() {
	printf 'gui/%s\n' "$(id -u)"
}

macos_service() {
	printf 'gui/%s/%s\n' "$(id -u)" "$1"
}

macos_plist_for_target() {
	target=$(expand_path "$1")

	case "$target" in
		*.plist|*/*)
			[ -f "$target" ] && {
				printf '%s\n' "$target"
				return 0
			}
			;;
	esac

	for plist in "$launchagents_dir"/*.plist; do
		[ -e "$plist" ] || continue
		base=${plist##*/}
		stem=${base%.plist}
		label=$(plist_value "$plist" Label)
		[ -n "$label" ] || label=$stem

		if [ "$target" = "$label" ] || [ "$target" = "$stem" ] || [ "$target" = "$base" ]; then
			printf '%s\n' "$plist"
			return 0
		fi
	done

	return 1
}

macos_label_for_name() {
	target=$(registry_target "$1")
	plist=$(macos_plist_for_target "$target" 2>/dev/null || true)

	if [ -n "$plist" ]; then
		label=$(plist_value "$plist" Label)
		if [ -n "$label" ]; then
			printf '%s\n' "$label"
		else
			base=${plist##*/}
			printf '%s\n' "${base%.plist}"
		fi
		return 0
	fi

	case "$target" in
		*.plist|*/*)
			die "no LaunchAgent plist found for $1 ($target)"
			;;
	esac

	printf '%s\n' "$target"
}

macos_is_loaded() {
	launchctl print "$(macos_service "$1")" >/dev/null 2>&1
}

macos_list() {
	need launchctl
	printf '%-24s %-48s %-10s %s\n' NAME LABEL STATE PLIST
	found=0

	for plist in "$launchagents_dir"/*.plist; do
		[ -e "$plist" ] || continue
		found=1
		base=${plist##*/}
		stem=${base%.plist}
		label=$(plist_value "$plist" Label)
		[ -n "$label" ] || label=$stem

		name=$stem
		if alias_name=$(registry_alias_for "$label" "$plist"); then
			name=$alias_name
		fi

		if macos_is_loaded "$label"; then
			state=loaded
		else
			state=unloaded
		fi

		printf '%-24s %-48s %-10s %s\n' "$name" "$label" "$state" "$plist"
	done

	[ "$found" -eq 1 ] || printf 'no LaunchAgents found in %s\n' "$launchagents_dir"
}

macos_status() {
	need launchctl
	[ $# -eq 1 ] || die "usage: $prog status <name>"

	name=$1
	target=$(registry_target "$name")
	label=$(macos_label_for_name "$name")
	plist=$(macos_plist_for_target "$target" 2>/dev/null || true)
	service=$(macos_service "$label")

	printf 'name:   %s\n' "$name"
	printf 'label:  %s\n' "$label"
	[ -n "$plist" ] && printf 'plist:  %s\n' "$plist"

	if macos_is_loaded "$label"; then
		printf 'state:  loaded\n\n'
		launchctl print "$service"
	else
		printf 'state:  unloaded\n'
	fi
}

macos_start() {
	need launchctl
	[ $# -eq 1 ] || die "usage: $prog start <name>"

	name=$1
	target=$(registry_target "$name")
	label=$(macos_label_for_name "$name")
	plist=$(macos_plist_for_target "$target" 2>/dev/null || true)

	if macos_is_loaded "$label"; then
		launchctl kickstart -k "$(macos_service "$label")"
	else
		[ -n "$plist" ] || die "$label is not loaded and no plist was found in $launchagents_dir"
		launchctl bootstrap "$(macos_domain)" "$plist"
		launchctl kickstart -k "$(macos_service "$label")" >/dev/null 2>&1 || true
	fi

	printf 'started %s\n' "$label"
}

macos_stop() {
	need launchctl
	[ $# -eq 1 ] || die "usage: $prog stop <name>"

	name=$1
	target=$(registry_target "$name")
	label=$(macos_label_for_name "$name")
	plist=$(macos_plist_for_target "$target" 2>/dev/null || true)
	service=$(macos_service "$label")

	if macos_is_loaded "$label"; then
		if ! launchctl bootout "$service" 2>/dev/null; then
			[ -n "$plist" ] || die "could not bootout $service and no plist fallback was found"
			launchctl bootout "$(macos_domain)" "$plist"
		fi
		printf 'stopped %s\n' "$label"
	else
		printf '%s is already stopped\n' "$label"
	fi
}

macos_restart() {
	need launchctl
	[ $# -eq 1 ] || die "usage: $prog restart <name>"

	label=$(macos_label_for_name "$1")
	if macos_is_loaded "$label"; then
		launchctl kickstart -k "$(macos_service "$label")"
		printf 'restarted %s\n' "$label"
	else
		macos_start "$1"
	fi
}

macos_logs() {
	need tail
	follow=0
	lines=100

	while [ $# -gt 0 ]; do
		case "$1" in
			-f|--follow)
				follow=1
				shift
				;;
			-n|--lines)
				shift
				[ $# -gt 0 ] || die "missing line count after -n"
				lines=$1
				shift
				;;
			--lines=*)
				lines=${1#--lines=}
				shift
				;;
			-*)
				die "unknown logs option: $1"
				;;
			*)
				break
				;;
		esac
	done

	[ $# -eq 1 ] || die "usage: $prog logs [-f] [-n lines] <name>"

	target=$(registry_target "$1")
	plist=$(macos_plist_for_target "$target" 2>/dev/null || true)
	[ -n "$plist" ] || die "no LaunchAgent plist found for $1"

	paths=$(
		{
			plist_value "$plist" StandardOutPath
			plist_value "$plist" StandardErrorPath
		} | awk 'NF && !seen[$0]++'
	)

	set --
	while IFS= read -r path; do
		[ -n "$path" ] || continue
		path=$(expand_path "$path")
		set -- "$@" "$path"
	done <<EOF
$paths
EOF

	[ $# -gt 0 ] || die "$plist has no StandardOutPath or StandardErrorPath"

	if [ "$follow" -eq 1 ]; then
		exec tail -n "$lines" -F "$@"
	else
		exec tail -n "$lines" "$@"
	fi
}

macos_enable() {
	need launchctl
	[ $# -eq 1 ] || die "usage: $prog enable <name>"
	label=$(macos_label_for_name "$1")
	launchctl enable "$(macos_service "$label")"
	printf 'enabled %s\n' "$label"
}

macos_disable() {
	need launchctl
	[ $# -eq 1 ] || die "usage: $prog disable <name>"
	label=$(macos_label_for_name "$1")
	launchctl disable "$(macos_service "$label")"
	printf 'disabled %s\n' "$label"
}

linux_unit_for_name() {
	target=$(registry_target "$1")
	case "$target" in
		*.service)
			printf '%s\n' "$target"
			;;
		*)
			printf '%s.service\n' "$target"
			;;
	esac
}

linux_list() {
	need systemctl
	systemctl --user list-units --type=service --all --no-pager
}

linux_status() {
	need systemctl
	[ $# -eq 1 ] || die "usage: $prog status <name>"
	systemctl --user status "$(linux_unit_for_name "$1")"
}

linux_start() {
	need systemctl
	[ $# -eq 1 ] || die "usage: $prog start <name>"
	systemctl --user start "$(linux_unit_for_name "$1")"
}

linux_stop() {
	need systemctl
	[ $# -eq 1 ] || die "usage: $prog stop <name>"
	systemctl --user stop "$(linux_unit_for_name "$1")"
}

linux_restart() {
	need systemctl
	[ $# -eq 1 ] || die "usage: $prog restart <name>"
	systemctl --user restart "$(linux_unit_for_name "$1")"
}

linux_logs() {
	need journalctl
	follow=0
	lines=100

	while [ $# -gt 0 ]; do
		case "$1" in
			-f|--follow)
				follow=1
				shift
				;;
			-n|--lines)
				shift
				[ $# -gt 0 ] || die "missing line count after -n"
				lines=$1
				shift
				;;
			--lines=*)
				lines=${1#--lines=}
				shift
				;;
			-*)
				die "unknown logs option: $1"
				;;
			*)
				break
				;;
		esac
	done

	[ $# -eq 1 ] || die "usage: $prog logs [-f] [-n lines] <name>"

	if [ "$follow" -eq 1 ]; then
		exec journalctl --user -u "$(linux_unit_for_name "$1")" -n "$lines" -f
	else
		exec journalctl --user -u "$(linux_unit_for_name "$1")" -n "$lines"
	fi
}

linux_enable() {
	need systemctl
	[ $# -eq 1 ] || die "usage: $prog enable <name>"
	systemctl --user enable "$(linux_unit_for_name "$1")"
}

linux_disable() {
	need systemctl
	[ $# -eq 1 ] || die "usage: $prog disable <name>"
	systemctl --user disable "$(linux_unit_for_name "$1")"
}

dispatch_platform() {
	os=$(uname -s 2>/dev/null || printf unknown)
	cmd=$1
	shift

	case "$os" in
		Darwin)
			case "$cmd" in
				list|ls) macos_list "$@" ;;
				status|st) macos_status "$@" ;;
				start|up) macos_start "$@" ;;
				stop|down) macos_stop "$@" ;;
				restart|re) macos_restart "$@" ;;
				logs|log) macos_logs "$@" ;;
				enable) macos_enable "$@" ;;
				disable) macos_disable "$@" ;;
				*) die "unknown command: $cmd" ;;
			esac
			;;
		Linux)
			case "$cmd" in
				list|ls) linux_list "$@" ;;
				status|st) linux_status "$@" ;;
				start|up) linux_start "$@" ;;
				stop|down) linux_stop "$@" ;;
				restart|re) linux_restart "$@" ;;
				logs|log) linux_logs "$@" ;;
				enable) linux_enable "$@" ;;
				disable) linux_disable "$@" ;;
				*) die "unknown command: $cmd" ;;
			esac
			;;
		*)
			die "unsupported OS: $os"
			;;
	esac
}

cmd=${1:-help}
case "$cmd" in
	-h|--help|help)
		usage
		;;
	alias)
		shift
		case $# in
			0) registry_print ;;
			2) registry_set "$1" "$2" ;;
			*) die "usage: $prog alias [short-name target]" ;;
		esac
		;;
	unalias)
		shift
		[ $# -eq 1 ] || die "usage: $prog unalias <short-name>"
		registry_unset "$1"
		;;
	*)
		shift
		dispatch_platform "$cmd" "$@"
		;;
esac

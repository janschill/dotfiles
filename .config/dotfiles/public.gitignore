# core.excludesFile for the public bare-repo worktree.
# Default-deny: only explicitly listed paths can be added.

/*

!/.gitconfig
!/.macos
!/.zshrc
!/.config/
!/bin/

/bin/*
!/bin/bb
!/bin/cliptouch
!/bin/geo-traceroute
!/bin/get-secret
!/bin/getsubs
!/bin/git-commit-info
!/bin/hoy
!/bin/llm-ctx
!/bin/my-tools
!/bin/notify
!/bin/rn
!/bin/serveit
!/bin/set-secret
!/bin/timer
!/bin/tracegeo
!/bin/update-system
!/bin/worklog

/.config/*
!/.config/dlv/
!/.config/dotfiles/
!/.config/git/
!/.config/homebrew/
!/.config/iterm2/
!/.config/k9s/
!/.config/mise/
!/.config/nvim/
!/.config/tmux/
!/.config/zsh/

/.config/dlv/*
!/.config/dlv/config.yml

/.config/dotfiles/*
!/.config/dotfiles/README.md
!/.config/dotfiles/install.sh
!/.config/dotfiles/macos.sh
!/.config/dotfiles/public.gitignore

/.config/git/*
!/.config/git/ignore

/.config/homebrew/*
!/.config/homebrew/Brewfile

/.config/iterm2/*
!/.config/iterm2/AppSupport
!/.config/iterm2/gruvbox-dark.itermcolors

/.config/k9s/*
!/.config/k9s/aliases.yaml
!/.config/k9s/config.yaml
!/.config/k9s/skins/
!/.config/k9s/skins/**

/.config/mise/*
!/.config/mise/config.toml

/.config/nvim/*
!/.config/nvim/init.vim

/.config/tmux/*
!/.config/tmux/tmux.conf
!/.config/tmux/gitmux/
!/.config/tmux/gitmux/.gitmux.conf

/.config/zsh/*
!/.config/zsh/aliases.zsh
!/.config/zsh/env.zsh
!/.config/zsh/history.zsh
!/.config/zsh/macos.zsh
!/.config/zsh/prompt.zsh
!/.config/zsh/python.zsh

# Defense in depth for secret-shaped files.
**/.DS_Store
**/.env
**/.envrc
**/.netrc
**/*.key
**/*.log
**/*.p12
**/*.pem
**/*.pfx
**/*.pid
**/*.sqlite
**/*.sqlite3
**/credentials.json
**/credentials.yaml
**/credentials.yml
**/id_ecdsa*
**/id_ed25519*
**/id_rsa*
**/secrets.json
**/secrets.yaml
**/secrets.yml

#!/usr/bin/env bash
set -euo pipefail

# Description: Set a secret in macOS Keychain

usage() {
  cat <<'EOF'
set-secret — store a secret in macOS Keychain

Usage:
  set-secret SECRET_NAME
  set-secret --help

Arguments:
  SECRET_NAME   The service name for the secret (you'll be prompted for the value)

Example:
  set-secret GITHUB_TOKEN
EOF
}

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  usage
  exit 0
fi

if [[ -z "${1:-}" ]]; then
  echo "Error: No secret name provided" >&2
  usage >&2
  exit 1
fi

if ! security add-generic-password -a "$USER" -s "$1" -w 2>/dev/null; then
  echo "Error: Could not set secret '$1' for account '$USER'" >&2
  exit 1
fi

echo "Secret '$1' successfully added for account '$USER'"
